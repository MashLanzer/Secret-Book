rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isCoupleUser(coupleId) {
      let parts = coupleId.split('_');
      return request.auth.uid in parts;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    match /couples/{coupleId} {
      allow read: if isAuthenticated() && isCoupleUser(coupleId);
      allow create: if isAuthenticated() && isCoupleUser(coupleId);
      allow update: if isAuthenticated() && isCoupleUser(coupleId);
    }

    match /couples/{coupleId}/history/{historyId} {
      allow read: if isAuthenticated() && isCoupleUser(coupleId);
      allow write: if isAuthenticated() && isCoupleUser(coupleId);
    }

    match /couples/{coupleId}/achievements/{achievementId} {
      allow read: if isAuthenticated() && isCoupleUser(coupleId);
      allow write: if isAuthenticated() && isCoupleUser(coupleId);
    }

    match /users/{userId}/experiences/{positionId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    match /customPositions/{coupleId}/items/{positionId} {
      allow read: if isAuthenticated() && isCoupleUser(coupleId);
      allow write: if isAuthenticated() && isCoupleUser(coupleId);
    }
  }
}
